# System update
alias update="sudo dnf update --refresh -y"

# Eza
alias ls="eza --icons --group-directories-last --color=always"
alias lsa="eza --icons --group-directories-first --all"
alias lslatr="eza --icons --long --all --sort=modified --reverse"

# Zoxide
alias cd="z"
alias ..="z .."

# Neovim
alias vim="nvim"

# Git
alias gpl="git pull"
alias gs="git status"
alias ga="git add"
alias gm="git commit"
alias gp="git push"
alias gmg="git merge"
alias gc="git checkout"
alias gf="git fetch"
alias gsh="git stash"
